{
  "name": "whcli",
  "version": "1.0.0",
  "description": "CLI for willhaben.at - agent automation ready",
  "type": "module",
  "bin": {
    "whcli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "npx tsx src/cli.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@steipete/sweet-cookie": "^0.1.0",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.1.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.6",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^8.57.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
